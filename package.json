{
  "name": "intentbridge",
  "version": "1.0.0",
  "description": "Cross-Rollup Intent Router — SC6019 Option 6",
  "scripts": {
    "node":           "npx hardhat node",
    "deploy":         "npx hardhat run scripts/deploy.js --network localhost",
    "deploy:sepolia": "npx hardhat run scripts/deploy.js --network sepolia",
    "router":         "node router/server.js",
    "benchmark":      "python3 analysis/benchmark.py",
    "test":           "npx hardhat test",
    "demo-routing":   "npx hardhat run scripts/demo-routing.js --network localhost"
  },
  "dependencies": {
    "cors":    "^2.8.5",
    "express": "^4.18.2",
    "dotenv":  "^16.3.1"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "hardhat": "^2.22.0"
  }
}
